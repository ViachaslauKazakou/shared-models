# Configuration for Remote Database Backup/Restore Script
# Copy this file to .env.backup and fill in your actual values
# Then run: source .env.backup && make backup-remote

# ===== SOURCE DATABASE (for creating backups) =====
SOURCE_DB_HOST=simple-ec2-db.cecurbs9fk6o.us-east-1.rds.amazonaws.com
SOURCE_DB_PORT=5432
SOURCE_DB_USER=postgres
SOURCE_DB_NAME=learnservicedatabase
SOURCE_DB_PASSWORD=vk-db-postgres

# ===== TARGET DATABASE (for restoring backups) =====
# These are used as defaults when restoring
# You will still be prompted to confirm/modify them during interactive restore
TARGET_DB_HOST=new-db.region.rds.amazonaws.com
TARGET_DB_PORT=5432
TARGET_DB_USER=postgres
TARGET_DB_NAME=learnservicedatabase
TARGET_DB_PASSWORD=your-target-password-here

# ===== BACKUP SETTINGS =====
# Directory where backups are stored (relative to project root)
BACKUP_DIR=./backups

# Optional: PostgreSQL connection timeout in seconds
PGCONNECT_TIMEOUT=10
